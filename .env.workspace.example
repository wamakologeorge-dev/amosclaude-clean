ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
WORKERS=1

SECRET_KEY=change-this-for-local-development
AUTH_COOKIE_SECURE=false
AUTH_SESSION_DAYS=7
AUTH_DB_PATH=data/auth.db

DATABASE_URL=postgresql+psycopg2://amosclaud:amosclaud@postgres:5432/amosclaud
REDIS_URL=redis://redis:6379/0

# First-party Amosclaud model runtime
AMOSCLAUD_MODEL_URL=http://amosclaud-model:11434
AMOSCLAUD_MODEL=qwen2.5-coder:3b
AMOSCLAUD_MODEL_TIMEOUT=120
AMOSCLAUD_ALLOW_EXTERNAL_ADAPTERS=false
# Set only when the internal model service is protected by a bearer token.
AMOSCLAUD_MODEL_TOKEN=

# Optional GitHub integration
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8000/auth/github/callback

# Required only for the browser IDE service in docker-compose.workspace.yml
WORKSPACE_PASSWORD=replace-with-a-strong-password
