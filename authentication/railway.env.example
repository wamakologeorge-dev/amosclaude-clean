# Amosclaud Autonomous authentication defaults for Railway
# Copy these names into Railway Variables. Never commit real secret values.

ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# Canonical Amosclaud Autonomous public endpoint.
AMOSCLAUD_API_URL=https://www.amosclaud.com
AMOSCLAUD_PUBLIC_ORIGIN=https://www.amosclaud.com

# Persistent Railway volume paths.
AUTH_DB_PATH=/data/auth/auth.db
REPOSITORY_STORAGE_PATH=/data/repositories
AMOSCLAUD_STORAGE_PATH=/data/platform
AMOSCLAUD_MODEL_HOME=/data/model

# Session and verification policy.
AUTH_COOKIE_SECURE=true
AUTH_SESSION_DAYS=7
AUTH_CODE_MINUTES=15
PASSKEY_SETUP_MINUTES=10

# WebAuthn/passkey identity. Keep RP ID and origin aligned with the public host.
PASSKEY_RP_ID=www.amosclaud.com
PASSKEY_ORIGIN=https://www.amosclaud.com
PASSKEY_RP_NAME=Amosclaud Autonomous

# Amosclaud-native mailbox addresses remain on the root mail domain.
AMOS_MAIL_DOMAIN=amosclaud.com

# Transactional security email. Configure these with an SMTP provider that has
# verified the amosclaud.com domain and its SPF, DKIM, and DMARC records.
AMOSCLAUD_SECURITY_FROM=no-reply@amosclaud.com
MAIL_SMTP_HOST=replace-in-railway-with-smtp-host
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=replace-in-railway-with-smtp-username
MAIL_SMTP_PASSWORD=replace-in-railway-with-smtp-password
MAIL_SMTP_TLS=true
MAIL_SMTP_FROM=no-reply@amosclaud.com

# Internal service contracts used by Autonomous, Fixer, repository, model, and metrics.
AMOSCLAUD_CREDENTIAL_URL=http://credential-authority:8001
AMOSCLAUD_MODEL_URL=http://model:8091
AMOSCLAUD_METRICS_URL=http://metrics:9090
AMOSCLAUD_REDIS_URL=redis://redis:6379/0

# Set these as Railway secrets, not literal values in this file.
SECRET_KEY=replace-in-railway-with-a-random-value-at-least-32-characters
AMOSCLAUD_API_KEY=replace-in-railway-with-an-amosclaud-issued-key

# Autonomous and Fixer remain governed by the single Amosclaud kernel.
AMOSCLAUD_AUTONOMOUS_ENABLED=true
AMOSCLAUD_FIXER_ENABLED=true
AMOSCLAUD_REQUIRE_VERIFICATION=true
AMOSCLAUD_PROTECT_DEFAULT_BRANCH=true
AMOSCLAUD_DEFAULT_BRANCH=main
