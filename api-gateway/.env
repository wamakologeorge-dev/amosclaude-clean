# amos-api-gateway/.env
# Environment variables for the API Gateway
JWT_SECRET_KEY="your-strong-jwt-secret-key-here" # REPLACE THIS WITH A REAL, STRONG KEY
JWT_ALGORITHM="HS256"

# URLs for your backend services
# When running with Docker Compose, these would be service names (e.g., http://service_a:8001)
# For local testing, use localhost
SERVICE_A_URL="http://localhost:8001"
SERVICE_B_URL="http://localhost:8002"
SERVICE_C_URL="http://localhost:8003"

# Rate Limiting (e.g., 60 requests per minute)
RATE_LIMIT_PER_MINUTE=60
