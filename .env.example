# Amosclaud Agent Server
ENVIRONMENT=production
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000
SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters

# Folder-owned persistent data
AUTH_DB_PATH=./data/auth.db
REPOSITORY_STORAGE_PATH=./data/repositories
STORAGE_PATH=./data/storage
DATABASE_URL=sqlite:///./data/amosclaud.db

# Customer agent access
# Purchase credits and create an API key from the Amosclaud account portal.
AMOSCLAUD_API_URL=https://amosclaud.com
AMOSCLAUD_API_KEY=
AMOSCLAUD_API_MODEL=amosclaud-agent

# Owner/private self-hosted model runtime (do not distribute owner credentials)
AMOSCLAUD_MODEL_URL=http://127.0.0.1:11434
AMOSCLAUD_MODEL=qwen2.5-coder:3b
AMOSCLAUD_MODEL_TOKEN=
AMOSCLAUD_MODEL_TIMEOUT=120

# Optional platform API access
EXTERNAL_API_KEY=
AUTH_SERVICE_URL=http://localhost:8001
