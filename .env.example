# Amosclaud — Railway environment template
#
# Copy these lines into Railway's Variables > Raw Editor.
# Never commit real passwords, tokens, API keys, or webhook secrets.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Amosclaud AI
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
# Railway normally provides PORT automatically. Keep this only for local use.
PORT=8000
WORKERS=1
ALLOWED_HOSTS=http://www.amosclaud.com/

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Use independent random values with at least 32 characters.
SECRET_KEY=
# Signs short-lived internal Amosclaud Byte commands. Do not expose this value
# to browsers, repository files, user jobs, or public API responses.
AMOSCLAUD_BYTE_BUS_SECRET=

# -----------------------------------------------------------------------------
# Database and persistent storage
# -----------------------------------------------------------------------------
# For Railway PostgreSQL, use the database URL supplied by the PostgreSQL
# service. AMOSCLAUD_PLATFORM_DATABASE_URL is shared by the API gateway,
# Autonomous Agent, root orchestrator, repository service, and CI workers.
DATABASE_URL=sqlite:///./data/amosclaud.db
AMOSCLAUD_PLATFORM_DATABASE_URL=sqlite:///./data/amosclaud-platform.db
AUTH_DB_PATH=./data/auth.db
REPOSITORY_STORAGE_PATH=./data/repositories
STORAGE_PATH=./data/storage

# -----------------------------------------------------------------------------
# Redis and background workers
# -----------------------------------------------------------------------------
# When Railway Redis is attached, set REDIS_URL from that service.
REDIS_URL=redis://localhost:6379/0
# Leave these blank to reuse REDIS_URL automatically.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# -----------------------------------------------------------------------------
# Amosclaud public service
# -----------------------------------------------------------------------------
AMOSCLAUD_PUBLIC_URL=http://www.amosclaud.com/
AMOSCLAUD_API_URL=http://www.amosclaud.com/
AMOSCLAUD_API_KEY=
AMOSCLAUD_API_MODEL=amosclaud-agent
AMOSCLAUD_AGENT_CREDITS_PER_REQUEST=1

# -----------------------------------------------------------------------------
# Amosclaud model runtime
# -----------------------------------------------------------------------------
# Use one model URL only. Point this to the deployed model service when present.
AMOSCLAUD_MODEL_URL=http://127.0.0.1:8091
AMOSCLAUD_MODEL=amosclaud-folder-v1
AMOSCLAUD_MODEL_TOKEN=
AMOSCLAUD_MODEL_TIMEOUT=120
AMOSCLAUD_MODEL_HOME=/data/amosclaud-model

# -----------------------------------------------------------------------------
# Optional external model provider
# -----------------------------------------------------------------------------
# Leave blank when Amosclaud's own model runtime is used.
OPENAI_API_KEY=
EXTERNAL_API_KEY=

# -----------------------------------------------------------------------------
# Optional supporting service
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# Billing — only required when Stripe billing is enabled
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FULL_MONTHLY_PRICE_ID=
STRIPE_FULL_ANNUAL_PRICE_ID=
STRIPE_AGENT_STARTER_PRICE_ID=
STRIPE_AGENT_BUILDER_PRICE_ID=
STRIPE_AGENT_STUDIO_PRICE_ID=

# -----------------------------------------------------------------------------
# Railway-provided variables
# -----------------------------------------------------------------------------
# Do not manually create or delete these. Railway injects them automatically:
# RAILWAY_PROJECT_ID
# RAILWAY_SERVICE_ID
# RAILWAY_ENVIRONMENT_ID
# RAILWAY_ENVIRONMENT
# RAILWAY_PUBLIC_DOMAIN
