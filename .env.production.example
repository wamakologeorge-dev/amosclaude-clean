POSTGRES_DB=amosclaud_db
POSTGRES_USER=amosclaud
POSTGRES_PASSWORD=replace-with-a-long-random-password
SECRET_KEY=replace-with-a-long-random-secret

# Production application URL
PLATFORM_BASE_URL=https://web-production-d94ca.up.railway.app
PUBLIC_APP_URL=https://web-production-d94ca.up.railway.app
API_BASE_URL=https://web-production-d94ca.up.railway.app

# Authentication and GitHub OAuth
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
GITHUB_CALLBACK_URL=https://web-production-d94ca.up.railway.app/api/v1/auth/github/callback
GITHUB_REPOSITORY_CALLBACK_URL=https://web-production-d94ca.up.railway.app/api/v1/github/callback
# Keep this value stable. Changing it disconnects stored GitHub authorizations.
GITHUB_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-encryption-secret
AUTH_COOKIE_SECURE=true
AUTH_SESSION_DAYS=7

# Persistent Railway volume paths
AUTH_DB_PATH=/data/auth.db
REPOSITORY_STORAGE_PATH=/data/repositories
MAX_REPOSITORIES_PER_USER=10
MAX_REPOSITORY_BYTES=524288000
