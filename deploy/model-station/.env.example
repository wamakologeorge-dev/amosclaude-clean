# Public Amosclaud server
AMOSCLAUD_API_URL=https://amosclaud.com

# Generated from the Amosclaud runner/station settings page
AMOSCLAUD_RUNNER_ID=replace-with-runner-id
AMOSCLAUD_RUNNER_TOKEN=replace-with-runner-token
AMOSCLAUD_RUNNER_WORKSPACE=/workspace
AMOSCLAUD_RUNNER_POLL_SECONDS=10

# Local model station authentication
AMOSCLAUD_MODEL_TOKEN=replace-with-a-long-random-secret
# Optional alternative accepted by the station for Amosclaud API clients.
# AMOSCLAUD_API_KEY=amos_replace-with-issued-api-key
AMOSCLAUD_FOLDER_MODEL_FALLBACK=true
AMOSCLAUD_MODEL_NAME=qwen2.5-coder:7b
AMOSCLAUD_MODEL_TIMEOUT=180
AMOSCLAUD_STATION_NAME=Amosclaud Primary Model Station

# The cloud backend must use the user ID that owns AMOSCLAUD_RUNNER_ID
# AMOSCLAUD_NETWORK_OWNER_USER_ID is configured on the Amosclaud server, not here.
